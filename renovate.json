{
  "extends": ["config:base", "helpers:pinGitHubActionDigests"],
  "prConcurrentLimit": 1,
  "baseBranches": ["master"],
  "semanticCommitType": "fix",
  "major": true,
  "labels": ["bot: dependencies"],
  "packageRules": [
    {
      "matchDepTypes": ["dependencies"],
      "matchPackagePatterns": ["^@verdaccio/"],
      "minimumReleaseAge": null
    },
    {
      "matchPackagePatterns": [
        "yeoman-generator",
        "yeoman-environment",
        "yeoman-test",
        "^yo$",
        "^@yeoman/"
      ],
      "groupName": "yeoman dependencies"
    },
    {
      "matchPackagePatterns": ["^@changesets/", "^changeset$"],
      "groupName": "changeset dependencies",
      "minimumReleaseAge": "120 days"
    },
    {
      "matchPackagePatterns": ["eslint", "prettier"],
      "groupName": "eslint and prettier",
      "minimumReleaseAge": "60 days"
    },
    {
      "matchPackagePatterns": ["vitest", "^@vitest/"],
      "groupName": "vitest",
      "minimumReleaseAge": "30 days"
    },
    {
      "matchPackagePatterns": ["typedoc"],
      "groupName": "typedoc",
      "minimumReleaseAge": "120 days"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackagePatterns": ["@types/", "typescript"],
      "groupName": "type tooling",
      "minimumReleaseAge": "60 days"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "excludePackagePatterns": [
        "eslint",
        "prettier",
        "vitest",
        "@vitest/",
        "@types/",
        "typescript",
        "typedoc"
      ],
      "groupName": "other devDependencies",
      "minimumReleaseAge": "60 days"
    },
    {
      "packageNames": ["actions/*", "github/codeql-action/*"],
      "groupName": "all actions",
      "groupSlug": "github-actions",
      "schedule": ["every 4 month"]
    },
    {
      "matchManagers": ["nvm", "nodenv", "node-version"],
      "matchPackageNames": ["node"],
      "allowedVersions": "<25"
    }
  ],
  "pinVersions": true,
  "postUpgradeTasks": {
    "commands": ["pnpm format"],
    "executionMode": "branch"
  }
}
